# Google Analytics 4
# Get your Measurement ID from GA4 > Admin > Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification
# Get value from GSC > Settings > Ownership verification > HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=your-gsc-verification-token

# Cloudflare Turnstile (contact form bot protection)
# Get keys at dash.cloudflare.com > Turnstile
# Vercel: use NEXT_PUBLIC_TURNSTILE_SITE_KEY or TURNSTILE_SITE_KEY (both work)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# Arcjet (rate limiting + email validation on /api/contact)
# Get key at app.arcjet.com
ARCJET_KEY=ajkey_...

# Resend (contact form email delivery)
# Create an API key at resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_TO_EMAIL=hello@nettrackers.co.uk
CONTACT_FROM_EMAIL=noreply@nettrackers.co.uk
