# Google Analytics 4
# Get your Measurement ID from GA4 > Admin > Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification
# Get value from GSC > Settings > Ownership verification > HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=your-gsc-verification-token

# Resend (contact form)
# Create an API key at resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL_TO=hello@bessdamm.com

# Upstash Redis (rate limiting on /api/contact)
# Create a Redis database at console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
